# Resend (email notifications)
# Sign up at resend.com — free tier works
RESEND_API_KEY=re_xxxxxxxxxxxx

# Where booking alerts go (defaults to your Gmail if unset)
NOTIFICATION_EMAIL=hello@backtraq.in

# Sender address — must be a verified domain in Resend
# Use onboarding@resend.dev for testing
FROM_EMAIL=hello@backtraq.in

# Google Sheets (optional — bookings log here)
# 1. Create a Google Cloud project
# 2. Enable the Sheets API
# 3. Create a Service Account, download JSON
# 4. Share your spreadsheet with the service account email
# 5. Paste credentials below
GOOGLE_SERVICE_ACCOUNT_EMAIL=backtraq@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXX\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# WhatsApp business number (digits only, with country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=919999000000
